#pragma once

#define QUATTRO_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define QUATTRO_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define QUATTRO_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define QUATTRO_VERSION_TEXT L"@PROJECT_VERSION@"
#define QUATTRO_BUILD_MARKER_TEXT L"@QUATTRO_BUILD_MARKER@"
#define QUATTRO_OFFICIAL_BUILD @QUATTRO_OFFICIAL_BUILD_VALUE@
#define QUATTRO_COMPRESSED_EMBEDDED_ASSETS @QUATTRO_COMPRESS_EMBEDDED_ASSETS_VALUE@

inline const wchar_t* QuattroVersionText() {
    return QUATTRO_VERSION_TEXT;
}

inline const wchar_t* QuattroBuildMarkerText() {
    return QUATTRO_BUILD_MARKER_TEXT;
}

inline bool QuattroIsOfficialBuild() {
    return QUATTRO_OFFICIAL_BUILD != 0;
}

inline bool QuattroUsesCompressedEmbeddedAssets() {
    return QUATTRO_COMPRESSED_EMBEDDED_ASSETS != 0;
}
