        <State name="disabled" track="@line" fill="@border" thumb="@surfaceRaised" border="@line"/>
    </Component>
    <Component name="tooltip">
        <Metric name="radius" value="6"/>
        <Metric name="borderWidth" value="1"/>
        <Metric name="paddingX" value="8"/>
        <Metric name="paddingY" value="7"/>
        <Metric name="lineGap" value="4"/>
        <State name="normal" bg="rgb(229,231,235)" text="rgb(17,24,39)" border="rgb(156,163,175)"/>
    </Component>
    <Component name="separator">
        <Metric name="thickness" value="1"/>
        <Metric name="inset" value="0"/>
        <State name="normal" line="@line"/>
    </Component>
</Theme>
